static void insert(int a[], unsigned int i) {
    unsigned int j;
    j = i;

    while(j > 0 && goes_before(a[j], a[j - 1])){
        swap(a, j, j - 1);
        //array_dump(a, length); 

        j = j - 1; 
    }
}

void insertion_sort(int a[], unsigned int length) {
for (unsigned int i = 1; i < length; ++i) {
        /* * Verificación de la Invariante:
         * Antes de insertar el elemento 'a[i]', el segmento 
         * anterior a[0, i) ya debe estar ordenado.
         */
        assert(array_is_sorted(a, i));

        // Llamada a la función de inserción que ya programaste
        insert(a, i);
    }
}


static unsigned int partition(int a[], unsigned int izq, unsigned int der) {
    unsigned int i;
    unsigned int j;
    unsigned int ppiv;

    ppiv = izq;
    i = izq + 1;
    j = der;
    
    while (i <= j){
        if(goes_before(a[i],a[ppiv])){
            i = i + 1;
        }
        if(goes_before(a[ppiv],a[j])){
            j = j - 1;
        }
        if(a[i] > a[ppiv] && a[j] < a[ppiv]){
            swap(a,i,j);
        }
    }

    swap(a,ppiv,j);
    ppiv = j;

    return ppiv;
}

static void quick_sort_rec(int a[], unsigned int izq, unsigned int der) {
    /* * Usamos una variable para guardar el índice del pivote 
     * que nos va a devolver la función partition() que ya viene armada.
     */
    unsigned int pivote;

    if (der > izq) {
        // LLAMADA a la función ya existente en sort_helpers.o
        pivote = partition(a, izq, der);

        // Recursión para la mitad izquierda
        // (el if es para evitar que si pivote es 0, al restar 1 de un unsigned de error)
        if (pivote > izq) {
            quick_sort_rec(a, izq, pivote - 1);
        }

        // Recursión para la mitad derecha
        quick_sort_rec(a, pivote + 1, der);
    }
}

void quick_sort(int a[], unsigned int length) {
     quick_sort_rec(a, 0, (length == 0) ? 0 : length - 1);
